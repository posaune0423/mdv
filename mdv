#!/bin/sh

set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
TARGET="$SCRIPT_DIR/target/debug/mdv"

needs_build=0

if [ ! -x "$TARGET" ]; then
  needs_build=1
elif find \
  "$SCRIPT_DIR/src" \
  "$SCRIPT_DIR/tests" \
  "$SCRIPT_DIR/Cargo.toml" \
  "$SCRIPT_DIR/Cargo.lock" \
  -type f -newer "$TARGET" 2>/dev/null | grep -q .; then
  needs_build=1
fi

if [ "$needs_build" -eq 1 ]; then
  cargo build --quiet --manifest-path "$SCRIPT_DIR/Cargo.toml" --bin mdv
fi

exec "$TARGET" "$@"
